# Copy to .env for local MCP + Docker MSSQL development.
# Never commit real credentials.

# --- SQL Server connection (used by the MCP server) ---
SERVER_NAME=127.0.0.1
DATABASE_NAME=AppDB
DATABASES=AppDB,ReportingDB
DB_USER=sa
DB_PASSWORD=Str0ng!Passw0rd
TRUST_SERVER_CERTIFICATE=true
READONLY=false
ENABLE_DDL=false
REQUIRE_WRITE_PREVIEW=true

# --- Optional MCP transport ---
# MCP_TRANSPORT=stdio
# MCP_TRANSPORT=http
# MCP_HTTP_HOST=127.0.0.1
# MCP_HTTP_PORT=3333

# --- Docker compose overrides (scripts/mssql-*.sh) ---
MSSQL_SA_PASSWORD=Str0ng!Passw0rd
MSSQL_HOST_PORT=1433
# MSSQL_CONTAINER_NAME=mssql-mcp-dev
