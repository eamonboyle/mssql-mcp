# Copy to .env for local MCP + Docker MSSQL development.
# Never commit real credentials.

# --- Required MCP server configuration ---
SERVER_NAME=127.0.0.1
DATABASE_NAME=AppDB
DATABASES=AppDB,ReportingDB
DB_USER=sa
DB_PASSWORD=Str0ng!Passw0rd
TRUST_SERVER_CERTIFICATE=true
READONLY=false
ENABLE_DDL=false

# --- Optional MCP server configuration ---
# Leave SERVER_PORT unset to use the SQL Server driver default port (1433).
# SERVER_PORT=1434
# CONNECTION_TIMEOUT=30
# QUERY_TIMEOUT_MS=30000
# MAX_ROWS=10000
# MAX_WRITE_ROWS=100
# REQUIRE_WRITE_PREVIEW=true
# MCP_TRANSPORT=stdio
# MCP_TRANSPORT=http
# MCP_HTTP_HOST=127.0.0.1
# MCP_HTTP_PORT=3333
# MCP_BASE_URL=https://mcp.example.com

# --- Docker compose overrides (scripts/mssql-*.sh) ---
MSSQL_SA_PASSWORD=Str0ng!Passw0rd
MSSQL_HOST_PORT=1433
# MSSQL_CONTAINER_NAME=mssql-mcp-dev
